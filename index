      .empty-state svg {
        width: 48px;
        height: 48px;
        margin-bottom: 16px;
        opacity: 0.5;
      }
      .empty-state h4 {
        font-size: 1.1rem;
        color: var(--text-main);
        margin-bottom: 8px;
      }
    </style>
  </head>
  <body>
    <nav>
      <h1>Plan<span>OS</span></h1>
      <div class="nav-item active" onclick="switchView('timetable', this)">
        <svg
          width="20"
