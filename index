<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PlanOS</title>
    <style>
      /* ==========================================
           1. 现代设计系统 (Design Tokens)
           ========================================== */
      :root {
        --primary: #6366f1;
        --primary-hover: #4f46e5;
        --primary-light: #e0e7ff;
        --bg-body: #f8fafc;
        --surface: #ffffff;
        --surface-hover: #f1f5f9;
        --text-main: #0f172a;
        --text-muted: #64748b;
        --text-disabled: #94a3b8;
        --border-light: #e2e8f0;
        --success: #10b981;
        --danger: #ef4444;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md:
          0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg:
          0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        --radius-md: 12px;
        --radius-lg: 16px;
        --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        --hour-height: 64px;
        --hour-width: 90px;
        --day-height: 72px;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background-color: var(--bg-body);
        color: var(--text-main);
        display: flex;
        height: 100vh;
        overflow: hidden;
        font-family:
          "Inter",
          -apple-system,
          sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
      }

      nav {
        width: 260px;
        background: var(--surface);
        padding: 32px 20px;
        border-right: 1px solid var(--border-light);
        display: flex;
        flex-direction: column;
        z-index: 10;
      }
      nav h1 {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 40px;
        text-align: left;
        padding-left: 12px;
        letter-spacing: -0.02em;
      }
      nav h1 span {
        color: var(--primary);
      }
      .nav-item {
        padding: 14px 16px;
        margin-bottom: 8px;
        border-radius: 10px;
        cursor: pointer;
        transition: var(--transition);
        color: var(--text-muted);
        font-weight: 500;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .nav-item:hover {
        background: var(--surface-hover);
        color: var(--text-main);
      }
      .nav-item.active {
        background: var(--primary);
        color: white;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
      }

      main {
        flex: 1;
        padding: 40px;
        overflow-y: auto;
        position: relative;
      }
      .view-section {
        display: none;
        animation: slideFadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .view-section.active {
        display: block;
      }
      @keyframes slideFadeUp {
        from {
          opacity: 0;
          transform: translateY(15px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .card {
        background: var(--surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-light);
        padding: 30px;
        margin-bottom: 30px;
      }
      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
      }
      .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.01em;
      }

      button {
        background: var(--primary);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.9rem;
        transition: var(--transition);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
      }
      button:hover {
        background: var(--primary-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
      }
      button:active {
        transform: translateY(0);
      }
      .btn-ghost {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--border-light);
      }
      .btn-ghost:hover {
        background: var(--surface-hover);
        color: var(--text-main);
        box-shadow: none;
      }

      /* ==========================================
           课表视图 (日历与甘特图)
           ========================================== */
      .calendar-wrapper {
        border: 1px solid var(--border-light);
        border-radius: var(--radius-md);
        overflow: hidden;
        background: var(--surface);
      }
      .calendar-header {
        display: flex;
        border-bottom: 1px solid var(--border-light);
        background: var(--bg-body);
      }
      .header-spacer {
        width: 70px;
        border-right: 1px solid var(--border-light);
        flex-shrink: 0;
      }
      .day-header {
        flex: 1;
        text-align: center;
        padding: 16px 0;
        font-weight: 600;
        border-right: 1px solid var(--border-light);
        color: var(--text-muted);
        font-size: 0.9rem;
      }
      .day-header:last-child {
        border-right: none;
      }

      .calendar-body {
        display: flex;
        height: 65vh;
        overflow-y: auto;
        position: relative;
      }
      .time-axis {
        width: 70px;
        border-right: 1px solid var(--border-light);
        background: var(--bg-body);
        flex-shrink: 0;
      }
      .time-label {
        height: var(--hour-height);
        text-align: right;
        padding-right: 12px;
        font-size: 0.8rem;
        color: var(--text-disabled);
        font-weight: 500;
        position: relative;
        top: -10px;
      }

      .day-column {
        flex: 1;
        border-right: 1px solid var(--border-light);
        position: relative;
        background-image: linear-gradient(
          to bottom,
          var(--border-light) 1px,
          transparent 1px
        );
        background-size: 100% var(--hour-height);
        cursor: crosshair;
        transition: background-color 0.2s;
        min-width: 120px;
      }
      .day-column:hover {
        background-color: rgba(99, 102, 241, 0.02);
      }

      .class-block {
        position: absolute;
        left: 6px;
        right: 6px;
        border-radius: 6px;
        padding: 8px 10px;
        font-size: 0.85rem;
        overflow: hidden;
        border-left: 4px solid;
        cursor: pointer;
        transition: var(--transition);
        z-index: 5;
        line-height: 1.4;
      }
      .class-block:hover {
        transform: scale(1.02) translateY(-2px);
        z-index: 10;
        box-shadow: var(--shadow-md);
        filter: brightness(0.95);
      }
      .class-title {
        font-weight: 700;
        margin-bottom: 4px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .class-room {
        font-size: 0.75rem;
        opacity: 0.8;
        font-weight: 500;
      }

      .calendar-horizontal {
        display: flex;
        flex-direction: column;
        overflow-x: auto;
        overflow-y: auto;
        height: 65vh;
        background: var(--surface);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-md);
      }
      .time-header-row {
        display: flex;
        border-bottom: 1px solid var(--border-light);
        background: var(--bg-body);
        position: sticky;
        top: 0;
        z-index: 20;
        width: max-content;
        min-width: 100%;
      }
      .time-header-cell {
        width: var(--hour-width);
        flex-shrink: 0;
        padding: 12px 0;
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 600;
        border-right: 1px solid var(--border-light);
        padding-left: 10px;
      }
      .day-row-container {
        display: flex;
        flex-direction: column;
        width: max-content;
        min-width: 100%;
      }
      .day-row {
        display: flex;
        border-bottom: 1px solid var(--border-light);
        height: var(--day-height);
      }
      .day-row:last-child {
        border-bottom: none;
      }
      .day-label-cell {
        width: 70px;
        flex-shrink: 0;
        background: var(--bg-body);
        border-right: 1px solid var(--border-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-muted);
        position: sticky;
        left: 0;
        z-index: 15;
        box-shadow: 2px 0 5px rgba(0, 0, 0, 0.03);
      }
      .day-track {
        flex: 1;
        position: relative;
        background-image: linear-gradient(
          to right,
          var(--border-light) 1px,
          transparent 1px
        );
        background-size: var(--hour-width) 100%;
        cursor: crosshair;
        min-width: calc(16 * var(--hour-width));
      }
      .day-track:hover {
        background-color: rgba(99, 102, 241, 0.02);
      }
      .class-block-h {
        position: absolute;
        top: 8px;
        bottom: 8px;
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 0.85rem;
        overflow: hidden;
        border-left: 4px solid;
        cursor: pointer;
        transition: var(--transition);
        z-index: 5;
        line-height: 1.4;
        display: flex;
        flex-direction: column;
        justify-content: center;
        box-shadow: var(--shadow-sm);
      }
      .class-block-h:hover {
        transform: scale(1.01) translateY(-1px);
        z-index: 10;
        box-shadow: var(--shadow-md);
        filter: brightness(0.95);
      }
      .class-title-h {
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .class-room-h {
        font-size: 0.75rem;
        opacity: 0.8;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-top: 2px;
      }

      /* 色块选择器 */
      .color-picker {
        display: flex;
        gap: 12px;
        margin-top: 8px;
        flex-wrap: wrap;
      }
      .color-swatch {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        cursor: pointer;
        transition: var(--transition);
        border: 2px solid transparent;
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .color-swatch:hover {
        transform: scale(1.1);
      }
      .color-swatch.selected {
        transform: scale(1.15);
        box-shadow:
          0 0 0 2px var(--surface),
          0 0 0 4px var(--primary);
      }

      /* ==========================================
           项目与作业卡片 (全新主卡片拖拽样式)
           ========================================== */
      .project-input-area {
        display: flex;
        gap: 12px;
        margin-bottom: 30px;
        background: var(--surface);
        padding: 20px;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-light);
        box-shadow: var(--shadow-sm);
      }
      .project-input-area input {
        flex: 1;
        padding: 12px 16px;
        border: 1px solid var(--border-light);
        border-radius: 8px;
        font-size: 1rem;
        transition: var(--transition);
        background: var(--bg-body);
      }
      .project-input-area input:focus {
        outline: none;
        border-color: var(--primary);
        background: var(--surface);
        box-shadow: 0 0 0 3px var(--primary-light);
      }
      .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 24px;
        align-items: start;
      }

      .project-card {
        background: var(--surface);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-md);
        padding: 24px;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.2s,
          box-shadow 0.2s,
          opacity 0.2s,
          border 0.2s;
      }
      .project-card:hover {
        box-shadow: var(--shadow-md);
        border-color: #cbd5e1;
      }

      /* 主卡片拖拽时的悬浮态与占位态 */
      .project-card.dragging-card {
        opacity: 0.6;
        transform: scale(0.98);
        border: 2px dashed var(--primary);
        z-index: 10;
        box-shadow: none;
      }
      .project-card.drag-over-card {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px var(--primary-light);
        transform: scale(1.02);
        z-index: 10;
      }

      .project-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
      }
      .project-card-header h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text-main);
        margin: 0;
        line-height: 1.3;
      }

      /* 主卡片的拖拽手柄 */
      .card-drag-handle {
        display: flex;
        align-items: center;
        cursor: grab;
        color: var(--text-disabled);
        transition: color 0.2s;
        margin-right: 10px;
      }
      .card-drag-handle:active {
        cursor: grabbing;
      }
      .project-card:hover .card-drag-handle {
        color: var(--text-muted);
      }
      .card-drag-handle:hover {
        color: var(--text-main);
      }

      .progress-container {
        width: 100%;
        background: var(--bg-body);
        height: 6px;
        border-radius: 4px;
        margin-bottom: 20px;
        overflow: hidden;
      }
      .progress-bar {
        height: 100%;
        background: linear-gradient(90deg, var(--primary), #818cf8);
        transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* 子任务拖拽相关 */
      .task-list {
        flex: 1;
        overflow-y: auto;
        max-height: 280px;
        margin-bottom: 16px;
        padding-right: 4px;
      }
      .task-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5f9;
        transition:
          opacity 0.2s,
          background 0.2s,
          border 0.2s;
      }
      .task-item:last-child {
        border-bottom: none;
      }
      .task-item.dragging {
        opacity: 0.4;
        background: var(--surface-hover);
        border-radius: 6px;
      }
      .task-item.drag-over {
        border-top: 2px dashed var(--primary);
        padding-top: 8px;
      }

      .task-item-left {
        display: flex;
        align-items: center;
        font-size: 0.95rem;
        color: var(--text-main);
        font-weight: 500;
        transition: var(--transition);
      }
      .task-item.completed .task-item-left {
        color: var(--text-disabled);
        text-decoration: line-through;
      }

      /* 子任务手柄 */
      .drag-handle {
        display: flex;
        align-items: center;
        cursor: grab;
        color: var(--text-disabled);
        opacity: 0;
        transition: opacity 0.2s;
        margin-right: 8px;
      }
      .drag-handle:active {
        cursor: grabbing;
      }
      .task-item:hover .drag-handle {
        opacity: 1;
      }

      .custom-checkbox {
        position: relative;
        display: inline-flex;
        align-items: center;
        cursor: pointer;
      }
      .custom-checkbox input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
        height: 0;
        width: 0;
      }
      .checkmark {
        width: 20px;
        height: 20px;
        border: 2px solid var(--border-light);
        border-radius: 6px;
        background: var(--surface);
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 12px;
      }
      .custom-checkbox:hover input ~ .checkmark {
        border-color: var(--primary);
      }
      .custom-checkbox input:checked ~ .checkmark {
        background: var(--primary);
        border-color: var(--primary);
      }
      .checkmark::after {
        content: "";
        display: none;
        width: 5px;
        height: 10px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
        margin-bottom: 2px;
      }
      .custom-checkbox input:checked ~ .checkmark::after {
        display: block;
      }

      .add-subtask-area {
        display: flex;
        gap: 8px;
        margin-top: auto;
        position: relative;
      }
      .add-subtask-area input {
        flex: 1;
        padding: 10px 14px;
        border: 1px solid var(--border-light);
        border-radius: 6px;
        font-size: 0.9rem;
        transition: var(--transition);
      }
      .add-subtask-area input:focus {
        outline: none;
        border-color: var(--primary);
      }
      .icon-btn {
        background: none;
        border: none;
        padding: 6px;
        border-radius: 6px;
        cursor: pointer;
        color: var(--text-muted);
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .icon-btn:hover {
        background: var(--surface-hover);
        color: var(--text-main);
        transform: translateY(0);
        box-shadow: none;
      }
      .icon-btn.danger:hover {
        background: #fef2f2;
        color: var(--danger);
      }
      .task-item:hover .delete-btn {
        opacity: 1;
      }
      .delete-btn {
        opacity: 0;
      }

      /* 专注与模态框 */
      .timer-container {
        text-align: center;
        padding: 60px 0;
        max-width: 600px;
        margin: 0 auto;
      }
      .time-display {
        font-size: 7rem;
        font-weight: 800;
        color: var(--text-main);
        font-variant-numeric: tabular-nums;
        margin: 30px 0;
        letter-spacing: -0.03em;
        text-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      }
      .timer-modes {
        display: inline-flex;
        background: var(--bg-body);
        padding: 4px;
        border-radius: 10px;
        margin-bottom: 10px;
        border: 1px solid var(--border-light);
      }
      .timer-modes button {
        background: transparent;
        color: var(--text-muted);
        border: none;
        box-shadow: none;
        font-weight: 500;
        padding: 8px 24px;
        border-radius: 6px;
      }
      .timer-modes button.active {
        background: var(--surface);
        color: var(--text-main);
        box-shadow: var(--shadow-sm);
      }
      .timer-modes button:hover:not(.active) {
        background: rgba(0, 0, 0, 0.02);
        transform: none;
      }

      .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(4px);
        z-index: 100;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .modal-overlay.active {
        display: flex;
        opacity: 1;
      }
      .modal-content {
        background: var(--surface);
        padding: 32px;
        border-radius: var(--radius-lg);
        width: 500px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: var(--shadow-lg);
        transform: scale(0.95);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }
      .modal-overlay.active .modal-content {
        transform: scale(1);
      }
      .modal-content h3 {
        margin-bottom: 24px;
        color: var(--text-main);
        font-size: 1.25rem;
      }
      .form-group {
        margin-bottom: 16px;
      }
      .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
      }
      .form-group input,
      .form-group select {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--border-light);
        border-radius: 8px;
        background: var(--bg-body);
        font-size: 0.95rem;
        transition: var(--transition);
      }
      .form-group input:focus,
      .form-group select:focus {
        outline: none;
        border-color: var(--primary);
        background: var(--surface);
      }
      .schedule-row {
        display: flex;
        gap: 8px;
        align-items: center;
        background: var(--bg-body);
        padding: 12px;
        border-radius: 8px;
        border: 1px solid var(--border-light);
        margin-bottom: 8px;
      }
      .schedule-row select,
      .schedule-row input {
        padding: 8px;
        border: 1px solid var(--border-light);
        border-radius: 6px;
        font-size: 0.9rem;
        flex: 1;
        background: var(--surface);
      }
      .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 32px;
      }

      #toast-container {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none;
      }
      .toast {
        background: var(--text-main);
        color: white;
        padding: 14px 24px;
        border-radius: 8px;
        box-shadow: var(--shadow-lg);
        font-size: 0.95rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
        animation: slideInRight 0.3s forwards;
        pointer-events: auto;
      }
      .toast.success {
        border-left: 4px solid var(--success);
      }
      .toast.error {
        border-left: 4px solid var(--danger);
      }
      .toast.fade-out {
        animation: fadeOut 0.3s forwards;
      }
      @keyframes slideInRight {
        from {
          transform: translateX(100%);
          opacity: 0;
        }
        to {
          transform: translateX(0);
          opacity: 1;
        }
      }
      @keyframes fadeOut {
        to {
          opacity: 0;
          transform: translateY(10px);
        }
      }
      .empty-state {
        text-align: center;
        padding: 40px 20px;
