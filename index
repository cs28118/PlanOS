          viewBox="0 0 24 24"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        时间轴视图
      </div>
      <div class="nav-item" onclick="switchView('assignments', this)">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
          ></path>
          <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
        </svg>
        待处理作业
      </div>
      <div class="nav-item" onclick="switchView('projects', this)">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
          ></path>
        </svg>
        项目与目标
      </div>
      <div class="nav-item" onclick="switchView('focus', this)">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        心流实验室
      </div>
    </nav>

    <main>
      <section id="view-timetable" class="view-section active">
        <div class="section-header">
          <h2>日程安排</h2>
          <div style="display: flex; gap: 12px">
            <button
              class="btn-ghost"
              id="layout-toggle-btn"
              onclick="toggleLayout()"
            ></button>
            <button onclick="openModal()">
              <svg
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line></svg
              >新建
            </button>
          </div>
        </div>

        <div class="calendar-wrapper" id="calendar-vertical">
          <div class="calendar-header">
            <div class="header-spacer"></div>
            <div class="day-header">周一</div>
            <div class="day-header">周二</div>
            <div class="day-header">周三</div>
            <div class="day-header">周四</div>
            <div class="day-header">周五</div>
            <div class="day-header">周六</div>
            <div class="day-header">周日</div>
          </div>
          <div class="calendar-body" id="vertical-body">
            <div class="time-axis" id="v-time-axis"></div>
            <div
              class="day-column"
              data-day="1"
              onclick="handleVerticalClick(event, 1)"
            ></div>
            <div
              class="day-column"
              data-day="2"
              onclick="handleVerticalClick(event, 2)"
            ></div>
            <div
              class="day-column"
              data-day="3"
              onclick="handleVerticalClick(event, 3)"
            ></div>
            <div
              class="day-column"
              data-day="4"
              onclick="handleVerticalClick(event, 4)"
            ></div>
            <div
              class="day-column"
              data-day="5"
              onclick="handleVerticalClick(event, 5)"
            ></div>
            <div
              class="day-column"
              data-day="6"
              onclick="handleVerticalClick(event, 6)"
            ></div>
            <div
              class="day-column"
              data-day="7"
              onclick="handleVerticalClick(event, 7)"
            ></div>
          </div>
        </div>

        <div
          class="calendar-horizontal"
          id="calendar-horizontal"
          style="display: none"
        >
          <div class="time-header-row" id="h-time-header">
            <div
              class="header-spacer"
              style="
                width: 70px;
                flex-shrink: 0;
                position: sticky;
                left: 0;
                background: var(--bg-body);
                border-right: 1px solid var(--border-light);
                z-index: 30;
              "
            ></div>
          </div>
          <div class="day-row-container">
            <div class="day-row">
              <div class="day-label-cell">周一</div>
              <div
                class="day-track"
                data-h-day="1"
                onclick="handleHorizontalClick(event, 1)"
              ></div>
            </div>
            <div class="day-row">
              <div class="day-label-cell">周二</div>
              <div
                class="day-track"
                data-h-day="2"
                onclick="handleHorizontalClick(event, 2)"
              ></div>
            </div>
            <div class="day-row">
              <div class="day-label-cell">周三</div>
              <div
                class="day-track"
                data-h-day="3"
                onclick="handleHorizontalClick(event, 3)"
              ></div>
            </div>
            <div class="day-row">
              <div class="day-label-cell">周四</div>
              <div
                class="day-track"
                data-h-day="4"
                onclick="handleHorizontalClick(event, 4)"
              ></div>
            </div>
            <div class="day-row">
              <div class="day-label-cell">周五</div>
              <div
                class="day-track"
                data-h-day="5"
                onclick="handleHorizontalClick(event, 5)"
              ></div>
            </div>
            <div class="day-row">
              <div class="day-label-cell">周六</div>
              <div
                class="day-track"
                data-h-day="6"
                onclick="handleHorizontalClick(event, 6)"
              ></div>
            </div>
            <div class="day-row">
              <div class="day-label-cell">周日</div>
              <div
                class="day-track"
                data-h-day="7"
                onclick="handleHorizontalClick(event, 7)"
              ></div>
            </div>
          </div>
        </div>
      </section>

      <section id="view-assignments" class="view-section">
        <div class="section-header"><h2>待处理作业</h2></div>
        <div class="project-input-area">
          <input
            type="text"
            id="new-assignment-input"
            placeholder="输入学科或作业分类，例如：线性代数作业..."
            onkeypress="if (event.key === 'Enter') addAssignment();"
          />
          <button onclick="addAssignment()">创建分类</button>
        </div>
        <div class="project-grid" id="assignment-container"></div>
      </section>

      <section id="view-projects" class="view-section">
        <div class="section-header"><h2>长线项目与目标</h2></div>
        <div class="project-input-area">
          <input
            type="text"
            id="new-project-input"
            placeholder="输入长线项目名称，例如：期末总复习..."
            onkeypress="if (event.key === 'Enter') addProject();"
          />
          <button onclick="addProject()">创建项目</button>
        </div>
        <div class="project-grid" id="project-container"></div>
      </section>

      <section id="view-focus" class="view-section">
        <div class="card timer-container">
          <div class="timer-modes">
            <button
              id="mode-work"
              class="active"
              onclick="setTimerMode('work')"
            >
              沉浸专注</button
            ><button id="mode-break" onclick="setTimerMode('break')">
              短休息
            </button>
          </div>
          <div class="time-display" id="time-display">25:00</div>
          <div style="display: flex; justify-content: center; gap: 16px">
            <button
              id="timer-btn"
              onclick="toggleTimer()"
              style="padding: 14px 40px; font-size: 1.1rem; border-radius: 30px"
            >
              开始专注
            </button>
            <button
              class="btn-ghost"
              onclick="resetTimer()"
              style="padding: 14px 20px; border-radius: 30px"
            >
              <svg
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <polyline points="1 4 1 10 7 10"></polyline>
                <polyline points="23 20 23 14 17 14"></polyline>
                <path
                  d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"
                ></path>
              </svg>
            </button>
          </div>
        </div>
      </section>
    </main>

    <div id="toast-container"></div>

    <div
      class="modal-overlay"
      id="class-modal"
      onclick="if (event.target === this) closeModal();"
    >
      <div class="modal-content">
        <h3 id="modal-title">添加课程/事项</h3>
        <input type="hidden" id="c-id" /><input
          type="hidden"
          id="c-color-idx"
          value="0"
        />
        <div class="form-group">
          <label>课程名称</label
          ><input type="text" id="c-name" placeholder="例如：高等数学" />
        </div>
        <div class="form-group">
          <label>主题颜色</label>
          <div class="color-picker" id="color-picker-container"></div>
        </div>
        <div class="form-group">
          <label>地点/备注 (选填)</label
          ><input type="text" id="c-room" placeholder="例如：教学楼 A302" />
        </div>
        <div class="form-group">
          <div
            style="
              display: flex;
              justify-content: space-between;
              align-items: center;
              margin-bottom: 10px;
            "
          >
            <label style="margin: 0">上课时间段</label
            ><button
              class="btn-ghost"
              style="padding: 4px 10px; font-size: 0.8rem; height: auto"
              onclick="addScheduleRow()"
            >
              + 增加时间
            </button>
          </div>
          <div
            id="schedules-container"
            style="
              display: flex;
              flex-direction: column;
              max-height: 180px;
              overflow-y: auto;
              padding-right: 4px;
            "
          ></div>
        </div>
        <div class="modal-actions">
          <button
            class="icon-btn danger"
            id="btn-delete-class"
            onclick="deleteClass()"
            style="
              display: none;
              margin-right: auto;
              width: auto;
              padding: 10px 15px;
            "
          >
            删除
          </button>
          <button class="btn-ghost" onclick="closeModal()">取消</button>
          <button onclick="saveClass()">保存设定</button>
        </div>
      </div>
    </div>

    <script>
      function showToast(message, type = "success") {
        const container = document.getElementById("toast-container");
        const toast = document.createElement("div");
        toast.className = `toast ${type}`;
        const icon =
          type === "success"
            ? `<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`
            : `<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);
        setTimeout(() => {
          toast.classList.add("fade-out");
          setTimeout(() => toast.remove(), 300);
        }, 3000);
      }

      const START_HOUR = 8;
      const END_HOUR = 22;
      const HOUR_HEIGHT = 64;
      const HOUR_WIDTH = 90;
      let layoutMode = localStorage.getItem("campus_layout") || "vertical";

      function switchView(viewId, navElement) {
        document
          .querySelectorAll(".view-section")
          .forEach((el) => el.classList.remove("active"));
        document
          .querySelectorAll(".nav-item")
          .forEach((el) => el.classList.remove("active"));
        document.getElementById("view-" + viewId).classList.add("active");
        navElement.classList.add("active");
      }

      let appData = {
        classes: JSON.parse(localStorage.getItem("campus_classes_v2")) || [],
        projects: JSON.parse(localStorage.getItem("campus_projects")) || [],
        assignments:
          JSON.parse(localStorage.getItem("campus_assignments")) || [],
      };
      function saveData() {
        localStorage.setItem(
          "campus_classes_v2",
          JSON.stringify(appData.classes),
        );
        localStorage.setItem(
          "campus_projects",
          JSON.stringify(appData.projects),
        );
        localStorage.setItem(
          "campus_assignments",
          JSON.stringify(appData.assignments),
        );
      }

      const courseThemes = [
        { bg: "#e0e7ff", border: "#6366f1" },
        { bg: "#dbeafe", border: "#3b82f6" },
        { bg: "#dcfce7", border: "#10b981" },
        { bg: "#fef3c7", border: "#f59e0b" },
        { bg: "#fee2e2", border: "#ef4444" },
        { bg: "#fce7f3", border: "#ec4899" },
        { bg: "#f3e8ff", border: "#a855f7" },
        { bg: "#f1f5f9", border: "#64748b" },
      ];

      // ================== 日历与布局 ==================
      function initAxes() {
        const vAxis = document.getElementById("v-time-axis");
        vAxis.innerHTML = "";
        const hHeader = document.getElementById("h-time-header");
        hHeader.innerHTML =
          '<div class="header-spacer" style="width: 70px; flex-shrink: 0; position: sticky; left: 0; background: var(--bg-body); border-right: 1px solid var(--border-light); z-index: 30;"></div>';
        for (let i = START_HOUR; i <= END_HOUR; i++) {
          const vLabel = document.createElement("div");
          vLabel.className = "time-label";
          vLabel.innerText = `${i.toString().padStart(2, "0")}:00`;
          vAxis.appendChild(vLabel);
          const hLabel = document.createElement("div");
          hLabel.className = "time-header-cell";
          hLabel.innerText = `${i.toString().padStart(2, "0")}:00`;
          hHeader.appendChild(hLabel);
        }
        const extraH = document.createElement("div");
        extraH.className = "time-header-cell";
        extraH.style.borderRight = "none";
        hHeader.appendChild(extraH);
      }
      function toggleLayout() {
        layoutMode = layoutMode === "vertical" ? "horizontal" : "vertical";
        localStorage.setItem("campus_layout", layoutMode);
        applyLayoutUI();
      }
      function applyLayoutUI() {
        const btn = document.getElementById("layout-toggle-btn");
        const vWrap = document.getElementById("calendar-vertical");
        const hWrap = document.getElementById("calendar-horizontal");
        if (layoutMode === "vertical") {
          btn.innerHTML = `<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line></svg> 切换甘特横轴`;
          vWrap.style.display = "block";
          hWrap.style.display = "none";
        } else {
          btn.innerHTML = `<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line><line x1="15" y1="3" x2="15" y2="21"></line></svg> 切换日历纵轴`;
          vWrap.style.display = "none";
          hWrap.style.display = "flex";
        }
        renderClasses();
      }
      function renderClasses() {
        document.querySelectorAll(".class-block").forEach((el) => el.remove());
        document
          .querySelectorAll(".class-block-h")
          .forEach((el) => el.remove());
        appData.classes.forEach((cls) => {
          const cIdx =
            cls.colorIndex !== undefined
              ? cls.colorIndex
              : cls.id % courseThemes.length;
          const theme = courseThemes[cIdx] || courseThemes[0];
          const schedules = cls.schedules || [
            { day: cls.day, start: cls.start, duration: cls.duration },
          ];
          schedules.forEach((sch) => {
            if (sch.start < START_HOUR || sch.start >= END_HOUR + 1) return;
            if (layoutMode === "vertical") {
              const column = document.querySelector(
                `.day-column[data-day="${sch.day}"]`,
              );
              if (!column) return;
              const block = document.createElement("div");
              block.className = "class-block";
              block.style.background = theme.bg;
              block.style.borderLeftColor = theme.border;
              block.style.color = "#1e293b";
              block.style.top = `${(sch.start - START_HOUR) * HOUR_HEIGHT}px`;
              block.style.height = `${sch.duration * HOUR_HEIGHT}px`;
              block.onclick = (e) => {
                e.stopPropagation();
                openModal(cls.id);
              };
              block.innerHTML = `<div class="class-title">${cls.name}</div>${cls.room ? `<div class="class-room">📍 ${cls.room}</div>` : ""}`;
              column.appendChild(block);
            } else {
              const track = document.querySelector(
                `.day-track[data-h-day="${sch.day}"]`,
              );
              if (!track) return;
              const block = document.createElement("div");
              block.className = "class-block-h";
              block.style.background = theme.bg;
              block.style.borderLeftColor = theme.border;
              block.style.color = "#1e293b";
              block.style.left = `${(sch.start - START_HOUR) * HOUR_WIDTH}px`;
              block.style.width = `${sch.duration * HOUR_WIDTH}px`;
              block.onclick = (e) => {
                e.stopPropagation();
                openModal(cls.id);
              };
              block.innerHTML = `<div class="class-title-h">${cls.name}</div>${cls.room ? `<div class="class-room-h">📍 ${cls.room}</div>` : ""}`;
              track.appendChild(block);
            }
          });
        });
      }
      function renderColorPicker(selectedIdx) {
        const container = document.getElementById("color-picker-container");
        container.innerHTML = "";
        courseThemes.forEach((theme, idx) => {
          const swatch = document.createElement("div");
          swatch.className = `color-swatch ${idx == selectedIdx ? "selected" : ""}`;
          swatch.style.backgroundColor = theme.bg;
          swatch.style.borderLeftColor = theme.border;
          swatch.onclick = () => {
            document.getElementById("c-color-idx").value = idx;
            renderColorPicker(idx);
          };
          container.appendChild(swatch);
        });
      }
      function handleVerticalClick(event, day) {
        const y = event.clientY - event.target.getBoundingClientRect().top;
        openModal(
          null,
          day,
          Math.floor((START_HOUR + y / HOUR_HEIGHT) * 2) / 2,
        );
      }
      function handleHorizontalClick(event, day) {
        const x = event.clientX - event.target.getBoundingClientRect().left;
        openModal(null, day, Math.floor((START_HOUR + x / HOUR_WIDTH) * 2) / 2);
      }

      const modal = document.getElementById("class-modal");
      const schedulesContainer = document.getElementById("schedules-container");
      function createScheduleRow(day = 1, timeStr = "08:00", duration = 2) {
        const row = document.createElement("div");
        row.className = "schedule-row";
        row.innerHTML = `<select class="s-day"><option value="1" ${day == 1 ? "selected" : ""}>周一</option><option value="2" ${day == 2 ? "selected" : ""}>周二</option><option value="3" ${day == 3 ? "selected" : ""}>周三</option><option value="4" ${day == 4 ? "selected" : ""}>周四</option><option value="5" ${day == 5 ? "selected" : ""}>周五</option><option value="6" ${day == 6 ? "selected" : ""}>周六</option><option value="7" ${day == 7 ? "selected" : ""}>周日</option></select><input type="time" class="s-time" value="${timeStr}" required><div style="display:flex; align-items:center; gap:4px; flex:1;"><input type="number" class="s-duration" value="${duration}" step="0.5" min="0.5" max="14"><span style="font-size:0.8rem; color:var(--text-muted);">h</span></div><button type="button" class="icon-btn danger" onclick="this.parentElement.remove()" style="flex:none;"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>`;
        return row;
      }
      function addScheduleRow(day = 1, timeStr = "08:00", duration = 2) {
        schedulesContainer.appendChild(
          createScheduleRow(day, timeStr, duration),
        );
      }
      function openModal(
        classId = null,
        defaultDay = 1,
        defaultStartHour = 8.0,
      ) {
        document.getElementById("c-id").value = classId || "";
        const delBtn = document.getElementById("btn-delete-class");
        schedulesContainer.innerHTML = "";
        let colorIdx = 0;
        if (classId) {
          document.getElementById("modal-title").innerText = "编辑日程";
          delBtn.style.display = "block";
          const cls = appData.classes.find((c) => c.id === classId);
          document.getElementById("c-name").value = cls.name;
          document.getElementById("c-room").value = cls.room || "";
          colorIdx =
            cls.colorIndex !== undefined
              ? cls.colorIndex
              : cls.id % courseThemes.length;
          const schedules = cls.schedules || [
            { day: cls.day, start: cls.start, duration: cls.duration },
          ];
          schedules.forEach((sch) => {
            const timeStr = `${Math.floor(sch.start).toString().padStart(2, "0")}:${Math.round(
              (sch.start % 1) * 60,
            )
              .toString()
              .padStart(2, "0")}`;
            addScheduleRow(sch.day, timeStr, sch.duration);
          });
        } else {
          document.getElementById("modal-title").innerText = "新建日程";
          delBtn.style.display = "none";
          document.getElementById("c-name").value = "";
          document.getElementById("c-room").value = "";
          const timeStr = `${Math.floor(defaultStartHour).toString().padStart(2, "0")}:${Math.round(
            (defaultStartHour % 1) * 60,
          )
            .toString()
            .padStart(2, "0")}`;
          addScheduleRow(defaultDay, timeStr, 2);
        }
        document.getElementById("c-color-idx").value = colorIdx;
        renderColorPicker(colorIdx);
        modal.classList.add("active");
      }
      function closeModal() {
        modal.classList.remove("active");
      }
      function saveClass() {
        const id = document.getElementById("c-id").value,
          name = document.getElementById("c-name").value.trim(),
          room = document.getElementById("c-room").value.trim(),
          colorIndex = parseInt(document.getElementById("c-color-idx").value);
        if (!name) {
          showToast("请输入日程名称", "error");
          return;
        }
        const scheduleRows = document.querySelectorAll(".schedule-row");
        if (scheduleRows.length === 0) {
          showToast("请至少保留一个时间段", "error");
          return;
        }
        const schedules = [];
        let isValid = true;
        scheduleRows.forEach((row) => {
          const day = parseInt(row.querySelector(".s-day").value),
            timeStr = row.querySelector(".s-time").value,
            duration = parseFloat(row.querySelector(".s-duration").value);
          if (!timeStr) {
            isValid = false;
            return;
          }
          const [h, m] = timeStr.split(":").map(Number);
          schedules.push({ day, start: h + m / 60, duration });
        });
        if (!isValid) {
          showToast("请将时间填写完整", "error");
          return;
        }
        if (id) {
          const idx = appData.classes.findIndex((c) => c.id == id);
          if (idx > -1) {
            appData.classes[idx].name = name;
            appData.classes[idx].room = room;
            appData.classes[idx].schedules = schedules;
            appData.classes[idx].colorIndex = colorIndex;
          }
          showToast("更新成功");
        } else {
          appData.classes.push({
            id: Date.now(),
            name,
            room,
            schedules,
            colorIndex,
          });
          showToast("添加成功");
        }
        saveData();
        renderClasses();
        closeModal();
      }
      function deleteClass() {
        if (confirm("永久删除该日程？")) {
          appData.classes = appData.classes.filter(
            (c) => c.id != document.getElementById("c-id").value,
          );
          saveData();
          renderClasses();
          closeModal();
          showToast("已彻底删除");
        }
      }

      // ==========================================
      // 🔥 双重拖拽引擎 (Subtasks & Main Cards)
      // ==========================================
      let dragSource = null; // 子任务的拖拽源
      let cardDragSource = null; // 主卡片的拖拽源

      // ------ A. 子任务的拖拽事件 ------
      function handleDragStart(e, type, parentId, taskId) {
        e.stopPropagation(); // 阻止事件冒泡到主卡片
        dragSource = { type, parentId, taskId };
        e.target.classList.add("dragging");
        e.dataTransfer.effectAllowed = "move";
        e.dataTransfer.setData("text/plain", taskId);
      }
      function handleDragOver(e) {
        if (!dragSource) return; // 如果正在拖主卡片，子任务不响应
        e.preventDefault();
        e.stopPropagation();
        e.dataTransfer.dropEffect = "move";
        const target = e.currentTarget;
        if (target && !target.classList.contains("dragging"))
          target.classList.add("drag-over");
      }
      function handleDragLeave(e) {
        if (!dragSource) return;
        e.stopPropagation();
        e.currentTarget.classList.remove("drag-over");
      }
      function handleDragEnd(e) {
        e.stopPropagation();
        e.target.classList.remove("dragging");
        document
          .querySelectorAll(".task-item")
          .forEach((el) => el.classList.remove("drag-over"));
        dragSource = null;
      }
      function handleDrop(e, targetType, targetParentId, targetTaskId) {
        e.preventDefault();
        e.stopPropagation();
        e.currentTarget.classList.remove("drag-over");
        if (!dragSource) return;
        if (
          dragSource.type !== targetType ||
          dragSource.parentId !== targetParentId
        ) {
          showToast("只能在当前卡片内排序子任务", "error");
          return;
        }
        if (dragSource.taskId === targetTaskId) return;

        let dataArray =
          targetType === "project" ? appData.projects : appData.assignments;
        let parentObj = dataArray.find((p) => p.id === dragSource.parentId);
        if (parentObj) {
          const tasks = parentObj.tasks;
          const sourceIndex = tasks.findIndex(
            (t) => t.id === dragSource.taskId,
          );
          const targetIndex = tasks.findIndex((t) => t.id === targetTaskId);
          if (sourceIndex > -1 && targetIndex > -1) {
            const [movedItem] = tasks.splice(sourceIndex, 1);
            tasks.splice(targetIndex, 0, movedItem);
            saveData();
            if (targetType === "project") renderProjects();
            else renderAssignments();
          }
        }
      }

      // ------ B. 主卡片的拖拽事件 ------
      function handleCardDragStart(e, type, cardId) {
        if (
          e.target.classList.contains("task-item") ||
          e.target.closest(".task-item")
        )
          return; // 防止误触
        cardDragSource = { type, id: cardId };
        e.currentTarget.classList.add("dragging-card");
        e.dataTransfer.effectAllowed = "move";
        e.dataTransfer.setData("text/plain", cardId);
        e.stopPropagation();
      }
      function handleCardDragOver(e) {
        if (!cardDragSource) return; // 如果正在拖子任务，主卡片不响应
        e.preventDefault();
        e.stopPropagation();
        e.dataTransfer.dropEffect = "move";
        const target = e.currentTarget;
        if (target && !target.classList.contains("dragging-card"))
          target.classList.add("drag-over-card");
      }
      function handleCardDragLeave(e) {
        if (!cardDragSource) return;
        e.stopPropagation();
        e.currentTarget.classList.remove("drag-over-card");
      }
      function handleCardDragEnd(e) {
        e.stopPropagation();
        e.currentTarget.classList.remove("dragging-card");
        document
          .querySelectorAll(".project-card")
          .forEach((el) => el.classList.remove("drag-over-card"));
        cardDragSource = null;
      }
      function handleCardDrop(e, targetType, targetId) {
        e.preventDefault();
        e.stopPropagation();
        e.currentTarget.classList.remove("drag-over-card");
        if (!cardDragSource) return;
        if (cardDragSource.type !== targetType) {
          showToast("无法将作业拖入项目区", "error");
          return;
        }
        if (cardDragSource.id === targetId) return;

        let dataArray =
          targetType === "project-card"
            ? appData.projects
            : appData.assignments;
        const sourceIndex = dataArray.findIndex(
          (p) => p.id === cardDragSource.id,
        );
        const targetIndex = dataArray.findIndex((p) => p.id === targetId);

        if (sourceIndex > -1 && targetIndex > -1) {
          const [movedItem] = dataArray.splice(sourceIndex, 1);
          dataArray.splice(targetIndex, 0, movedItem);
          saveData();
          if (targetType === "project-card") renderProjects();
          else renderAssignments();
        }
        cardDragSource = null;
      }

      // ==========================================
      // 渲染函数：注入双重拖拽 HTML
      // ==========================================
      function generateTaskHtml(t, parentId, type) {
        return `<div class="task-item ${t.completed ? "completed" : ""}" draggable="true" ondragstart="handleDragStart(event, '${type}', ${parentId}, ${t.id})" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)" ondrop="handleDrop(event, '${type}', ${parentId}, ${t.id})"><div class="task-item-left"><div class="drag-handle" title="拖拽排序"><svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M8 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM8 12a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM8 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 12a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"></path></svg></div><label class="custom-checkbox"><input type="checkbox" ${t.completed ? "checked" : ""} onchange="${type === "project" ? "toggleTask" : "toggleAssignmentTask"}(${parentId}, ${t.id})"><span class="checkmark"></span></label><span>${t.text}</span></div><button class="icon-btn delete-btn danger" onclick="${type === "project" ? "deleteTask" : "deleteAssignmentTask"}(${parentId}, ${t.id})"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></button></div>`;
      }

      function renderAssignments() {
        const container = document.getElementById("assignment-container");
        container.innerHTML = "";
        if (appData.assignments.length === 0) {
          container.innerHTML = `<div class="empty-state"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg><h4>没有待处理作业</h4></div>`;
          return;
        }
        appData.assignments.forEach((assign) => {
          const total = assign.tasks.length,
            completed = assign.tasks.filter((t) => t.completed).length,
            progressPercent =
              total === 0 ? 0 : Math.round((completed / total) * 100);
          const card = document.createElement("div");
          card.className = "project-card";
          // 赋予主卡片可拖拽属性
          card.setAttribute("draggable", "true");
          card.ondragstart = (e) =>
            handleCardDragStart(e, "assign-card", assign.id);
          card.ondragover = handleCardDragOver;
          card.ondragleave = handleCardDragLeave;
          card.ondragend = handleCardDragEnd;
          card.ondrop = (e) => handleCardDrop(e, "assign-card", assign.id);

          const tasksHtml = assign.tasks
            .map((t) => generateTaskHtml(t, assign.id, "assign"))
            .join("");
          card.innerHTML = `<div class="project-card-header"><div style="display:flex; align-items:center;"><div class="card-drag-handle" title="拖拽排序整个分类"><svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M8 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM8 12a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM8 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 12a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"></path></svg></div><h3>${assign.name}</h3></div><button class="icon-btn danger" onclick="deleteAssignment(${assign.id})"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></button></div><div class="progress-container"><div class="progress-bar" style="width: ${progressPercent}%; background: linear-gradient(90deg, #10b981, #34d399);"></div></div><div class="task-list">${tasksHtml}</div><div class="add-subtask-area"><input type="text" id="assign-task-input-${assign.id}" placeholder="输入具体作业..." onkeypress="if(event.key==='Enter') addAssignmentTask(${assign.id})"></div>`;
          container.appendChild(card);
        });
      }
      function addAssignment() {
        const name = document
          .getElementById("new-assignment-input")
          .value.trim();
        if (!name) return;
        appData.assignments.push({ id: Date.now(), name: name, tasks: [] });
        saveData();
        renderAssignments();
        document.getElementById("new-assignment-input").value = "";
        showToast("作业分类已创建");
      }
      function deleteAssignment(assignId) {
        if (confirm("删除该作业分类？")) {
          appData.assignments = appData.assignments.filter(
            (a) => a.id !== assignId,
          );
          saveData();
          renderAssignments();
          showToast("已删除");
        }
      }
      function addAssignmentTask(assignId) {
        const input = document.getElementById(`assign-task-input-${assignId}`);
        const text = input.value.trim();
        if (!text) return;
        const assign = appData.assignments.find((a) => a.id === assignId);
        if (assign) {
          assign.tasks.push({ id: Date.now(), text: text, completed: false });
          saveData();
          renderAssignments();
          input.value = "";
        }
      }
      function toggleAssignmentTask(assignId, taskId) {
        const assign = appData.assignments.find((a) => a.id === assignId);
        if (assign) {
          const task = assign.tasks.find((t) => t.id === taskId);
          if (task) {
            task.completed = !task.completed;
            saveData();
            renderAssignments();
          }
        }
      }
      function deleteAssignmentTask(assignId, taskId) {
        const assign = appData.assignments.find((a) => a.id === assignId);
        if (assign) {
          assign.tasks = assign.tasks.filter((t) => t.id !== taskId);
          saveData();
          renderAssignments();
        }
      }

      function renderProjects() {
        const container = document.getElementById("project-container");
        container.innerHTML = "";
        if (appData.projects.length === 0) {
          container.innerHTML = `<div class="empty-state"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg><h4>没有长线项目</h4></div>`;
          return;
        }
        appData.projects.forEach((proj) => {
          const total = proj.tasks.length,
            completed = proj.tasks.filter((t) => t.completed).length,
            progressPercent =
              total === 0 ? 0 : Math.round((completed / total) * 100);
          const card = document.createElement("div");
          card.className = "project-card";
          // 赋予主卡片可拖拽属性
          card.setAttribute("draggable", "true");
          card.ondragstart = (e) =>
            handleCardDragStart(e, "project-card", proj.id);
          card.ondragover = handleCardDragOver;
          card.ondragleave = handleCardDragLeave;
          card.ondragend = handleCardDragEnd;
          card.ondrop = (e) => handleCardDrop(e, "project-card", proj.id);

          const tasksHtml = proj.tasks
            .map((t) => generateTaskHtml(t, proj.id, "project"))
            .join("");
          card.innerHTML = `<div class="project-card-header"><div style="display:flex; align-items:center;"><div class="card-drag-handle" title="拖拽排序整个项目"><svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M8 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM8 12a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM8 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 6a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 12a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM20 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"></path></svg></div><h3>${proj.name}</h3></div><button class="icon-btn danger" onclick="deleteProject(${proj.id})"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></button></div><div class="progress-container"><div class="progress-bar" style="width: ${progressPercent}%;"></div></div><div class="task-list">${tasksHtml}</div><div class="add-subtask-area"><input type="text" id="subtask-input-${proj.id}" placeholder="输入子任务..." onkeypress="if(event.key==='Enter') addSubTask(${proj.id})"></div>`;
          container.appendChild(card);
        });
      }
      function addProject() {
        const name = document.getElementById("new-project-input").value.trim();
        if (!name) return;
        appData.projects.push({ id: Date.now(), name: name, tasks: [] });
        saveData();
        renderProjects();
        document.getElementById("new-project-input").value = "";
        showToast("项目创建成功");
      }
      function deleteProject(projectId) {
        if (confirm("永久删除项目？")) {
          appData.projects = appData.projects.filter((p) => p.id !== projectId);
          saveData();
          renderProjects();
          showToast("已删除");
        }
      }
      function addSubTask(projectId) {
        const input = document.getElementById(`subtask-input-${projectId}`);
        const text = input.value.trim();
        if (!text) return;
        const proj = appData.projects.find((p) => p.id === projectId);
        if (proj) {
          proj.tasks.push({ id: Date.now(), text: text, completed: false });
          saveData();
          renderProjects();
          input.value = "";
        }
      }
      function toggleTask(projectId, taskId) {
        const proj = appData.projects.find((p) => p.id === projectId);
        if (proj) {
          const task = proj.tasks.find((t) => t.id === taskId);
          if (task) {
            task.completed = !task.completed;
            saveData();
            renderProjects();
          }
        }
      }
      function deleteTask(projectId, taskId) {
        const proj = appData.projects.find((p) => p.id === projectId);
        if (proj) {
          proj.tasks = proj.tasks.filter((t) => t.id !== taskId);
          saveData();
          renderProjects();
        }
      }

      // 专注模式
      let timer,
        isRunning = false,
        timeLeft = 25 * 60,
        currentMode = "work";
      function updateDisplay() {
        document.getElementById("time-display").textContent = `${Math.floor(
          timeLeft / 60,
        )
          .toString()
          .padStart(2, "0")}:${(timeLeft % 60).toString().padStart(2, "0")}`;
      }
      function setTimerMode(mode) {
        clearInterval(timer);
        isRunning = false;
        currentMode = mode;
        const btn = document.getElementById("timer-btn");
        btn.textContent = "开始专注";
        btn.style.background = "var(--primary)";
        document.getElementById("mode-work").classList.remove("active");
        document.getElementById("mode-break").classList.remove("active");
        document.getElementById(`mode-${mode}`).classList.add("active");
        timeLeft = mode === "work" ? 25 * 60 : 5 * 60;
        updateDisplay();
      }
      function toggleTimer() {
        const btn = document.getElementById("timer-btn");
        if (isRunning) {
          clearInterval(timer);
          btn.textContent = "继续";
          btn.style.background = "#f59e0b";
        } else {
          btn.textContent = "暂停";
          btn.style.background = "var(--danger)";
          timer = setInterval(() => {
            if (timeLeft > 0) {
              timeLeft--;
              updateDisplay();
            } else {
              clearInterval(timer);
              showToast("⏰ 计时结束！", "success");
              resetTimer();
            }
          }, 1000);
        }
        isRunning = !isRunning;
      }
      function resetTimer() {
        setTimerMode(currentMode);
      }

      window.onload = () => {
        initAxes();
        applyLayoutUI();
        renderProjects();
        renderAssignments();
      };
    </script>
  </body>
</html>
